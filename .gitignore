# Ignore generated PDF resumes
*.pdf

# Ignore the dynamic LaTeX snippets generated by the Python script
experience.tex
education.tex
skills.tex

# Ignore standard LaTeX temporary/auxiliary files (just in case the build crashes before the cleanup command runs)
*.aux
*.log
*.out
*.fls
*.fdb_latexmk
*.synctex.gz

# Ignore local environment variables
.env

# Ignore Python cache directories
__pycache__/
*.pyc